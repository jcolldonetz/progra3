# Activa el motor de reescritura de URL de Apache para que las reglas RewriteRule funcionen
RewriteEngine On
# Define la base de las URL reescritas para este proyecto en /progra3/
RewriteBase /progra3/

# Si entran a la base del proyecto, redirigir a /public/
RewriteRule ^$ public/ [L,R=302]

# Si ya está dentro de public, no seguir reescribiendo
RewriteRule ^public/ - [L]

# Si no es archivo ni carpeta real, enviar todo a public/index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)$ public/index.php [QSA,L]